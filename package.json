{
  "name": "recoil-strafe-trainer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev-electron.mjs",
    "dev:web": "vite --port=3000 --host=127.0.0.1",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "electron": "electron .",
    "pack:win": "npm run build && node ./scripts/package-win.mjs",
    "dist:win": "npm run build && node ./scripts/package-win.mjs",
    "dist:installer": "npm run build && electron-builder --win nsis portable --publish never",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "uiohook-napi": "^1.5.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.0",
    "@electron/packager": "^18.3.6",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.oceancourier.recoilstrafetrainer",
    "productName": "RecoilStrafeTrainer",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*",
      "node_modules/node-gyp-build/**/*"
    ],
    "win": {
      "artifactName": "${productName}-${version}-${arch}-${target}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
